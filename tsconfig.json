{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,

    "module": "ESNext",
    "moduleResolution": "Bundler",

    "lib": ["ES2022", "DOM", "DOM.Iterable"],

    "jsx": "react-jsx",

    "types": [
      "vite/client",
      "react",
      "react-dom"
    ],

    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "noEmit": true,

    "esModuleInterop": true,
    "strict": true,

    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,

    "skipLibCheck": true,

    "baseUrl": "./",
    "paths": {
      "@/*": ["src/*"],

      "@domain": ["src/app/domain/index.ts"],
      "@domain/*": ["src/app/domain/*"],

      "@application": ["src/app/application/index.ts"],
      "@application/*": ["src/app/application/*"],

      "@infrastructure": ["src/app/infrastructure/index.ts"],
      "@infrastructure/*": ["src/app/infrastructure/*"],

      "@presentation": ["src/app/presentation/index.ts"],
      "@presentation/*": ["src/app/presentation/*"],

      "@assets": ["src/assets/index.ts"],
      "@assets/*": ["src/assets/*"],

      "@i18n": ["src/assets/i18n/index.ts"],
      "@i18n/*": ["src/assets/i18n/*"]
    }
  },
  "include": ["src"]
}